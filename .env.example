# LLM — mock mode keeps local development/tests offline.
# Set LLM_MOCK=false and run Ollama locally to use real model calls.
LLM_MOCK=true
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# News search APIs — optional; searchers fall back gracefully when unset.
NEWSAPI_KEY=
GNEWS_KEY=

# Frontend: override if backend runs on a different port/host
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
